{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "appData": {
    "app": "monimmo-front",
    "version": "1"
  },
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/*.css",
          "/*.js",
          "/manifest.webmanifest",
          "/favicon.ico"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/icons/**",
          "/assets/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-network-first",
      "urls": [
        "/health",
        "/me/**",
        "/search**",
        "/users/**",
        "/properties/**",
        "/visits/**",
        "/calendar-events**",
        "/messages/**",
        "/vocals/**",
        "/files/**",
        "/review-queue/**",
        "/integrations/**",
        "http://localhost:3000/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 200,
        "maxAge": "1d",
        "timeout": "8s"
      }
    }
  ]
}
